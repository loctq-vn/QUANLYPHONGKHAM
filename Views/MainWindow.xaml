<Window x:Class="QUANLYPHONGKHAM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QUANLYPHONGKHAM"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Quản Lý Phòng Khám"
        Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TIÊU ĐỀ ===== -->
        <materialDesign:Card Grid.Row="0"
                             Padding="16"
                             Background="{DynamicResource MaterialDesign.Brush.Primary}"
                             Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                             materialDesign:ElevationAssist.Elevation="Dp4"
                             Margin="0,0,0,20">
            <TextBlock Text="BM1: Danh Sách Khám Bệnh"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </materialDesign:Card>

        <!-- ===== BỘ LỌC: NGÀY KHÁM + LOẠI PHÒNG + NÚT TÌM ===== -->
        <materialDesign:Card Grid.Row="1"
                             Padding="20"
                             Margin="0,0,0,20"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Ngày khám -->
                <DatePicker Grid.Column="0"
                            materialDesign:HintAssist.Hint="Ngày khám"
                            materialDesign:HintAssist.IsFloating="True"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            SelectedDate="{Binding NgayKham, Mode=TwoWay}"/>

                <!-- Loại phòng khám -->
                <ComboBox Grid.Column="2"
                          materialDesign:HintAssist.Hint="Loại phòng khám"
                          materialDesign:HintAssist.IsFloating="True"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding DanhSachLoaiPhong}"
                          DisplayMemberPath="TenLoaiPhongKham"
                          SelectedItem="{Binding SelectedLoaiPhong, Mode=TwoWay}"/>

                <!-- Nút Tìm kiếm -->
                <Button Grid.Column="4"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Command="{Binding TimKiemCommand}"
                        Height="56"
                        Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 VerticalAlignment="Center"
                                                 Width="22" Height="22"
                                                 Margin="0,0,8,0"/>
                        <TextBlock Text="Tìm kiếm"
                                   VerticalAlignment="Center"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- ===== BẢNG DANH SÁCH BỆNH NHÂN ===== -->
        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  ItemsSource="{Binding DanhSachBenhNhan}"
                  SelectedItem="{Binding SelectedBenhNhan, Mode=TwoWay}"
                  materialDesign:DataGridAssist.CellPadding="14 10 14 10"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="14 10 14 10"
                  HeadersVisibility="Column"
                  VerticalScrollBarVisibility="Auto"
                  Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã KB"
                                    Binding="{Binding MaKhamBenh}"
                                    Width="80"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Họ Tên"
                                    Binding="{Binding HoTen}"
                                    Width="2*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Giới Tính"
                                    Binding="{Binding GioiTinh}"
                                    Width="*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Năm Sinh"
                                    Binding="{Binding NamSinh}"
                                    Width="*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Địa Chỉ"
                                    Binding="{Binding DiaChi}"
                                    Width="2*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ===== NÚT THAO TÁC: THÊM / SỬA / XÓA ===== -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,16">
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Command="{Binding ThemBenhNhanCommand}"
                    Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AccountPlus"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                    <TextBlock Text="Thêm"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Command="{Binding SuaBenhNhanCommand}"
                    Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Pencil"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                    <TextBlock Text="Sửa"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Foreground="Red"
                    BorderBrush="Red"
                    Command="{Binding XoaBenhNhanCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Delete"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                    <TextBlock Text="Xóa"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ===== QUY ĐỊNH ===== -->
        <materialDesign:Card Grid.Row="4"
                             Padding="12"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,4">
                    <Run Text="Quy định 1:"/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="13"
                           Text="Có 2 loại phòng Khám: Phòng khám Thường và Phòng khám VIP. Số bệnh nhân khám tối đa mỗi ngày của Phòng khám Thường, Phòng khám VIP lần lượt là 40, 20."/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
