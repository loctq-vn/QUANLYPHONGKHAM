<Window x:Class="QUANLYPHONGKHAM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QUANLYPHONGKHAM"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Lập Danh Sách Khám Bệnh"
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TIÊU ĐỀ ===== -->
        <materialDesign:Card Grid.Row="0"
                             Padding="16"
                             Background="{DynamicResource MaterialDesign.Brush.Primary}"
                             Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                             materialDesign:ElevationAssist.Elevation="Dp4"
                             Margin="0,0,0,16">
            <TextBlock Text="BM1: Danh Sách Khám Bệnh"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </materialDesign:Card>

        <!-- ===== NGÀY KHÁM + LOẠI PHÒNG KHÁM ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Ngày khám -->
            <DatePicker Grid.Column="0"
                        materialDesign:HintAssist.Hint="Ngày khám"
                        materialDesign:HintAssist.IsFloating="True"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                        SelectedDate="{Binding NgayKham, Mode=TwoWay}"
                        Width="Auto"/>

            <!-- Loại phòng khám -->
            <ComboBox Grid.Column="2"
                      materialDesign:HintAssist.Hint="Loại phòng khám"
                      materialDesign:HintAssist.IsFloating="True"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      SelectedItem="{Binding LoaiPhongKham, Mode=TwoWay}">
                <ComboBoxItem Content="Phòng khám Thường"/>
                <ComboBoxItem Content="Phòng khám VIP"/>
            </ComboBox>
        </Grid>

        <!-- ===== FORM NHẬP THÔNG TIN BỆNH NHÂN ===== -->
        <materialDesign:Card Grid.Row="2"
                             Padding="16"
                             Margin="0,0,0,16"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Họ Tên -->
                <TextBox Grid.Row="0" Grid.Column="0"
                         materialDesign:HintAssist.Hint="Họ Tên"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         x:Name="txtHoTen"/>

                <!-- Giới Tính -->
                <ComboBox Grid.Row="0" Grid.Column="2"
                          materialDesign:HintAssist.Hint="Giới Tính"
                          materialDesign:HintAssist.IsFloating="True"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          x:Name="cboGioiTinh">
                    <ComboBoxItem Content="Nam"/>
                    <ComboBoxItem Content="Nữ"/>
                </ComboBox>

                <!-- Năm Sinh -->
                <TextBox Grid.Row="0" Grid.Column="4"
                         materialDesign:HintAssist.Hint="Năm Sinh"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         x:Name="txtNamSinh"/>

                <!-- Địa Chỉ -->
                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                         materialDesign:HintAssist.Hint="Địa Chỉ"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,16,0,0"
                         x:Name="txtDiaChi"/>
            </Grid>
        </materialDesign:Card>

        <!-- ===== BẢNG DANH SÁCH BỆNH NHÂN ===== -->
        <DataGrid Grid.Row="3"
                  x:Name="dgDanhSach"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="12 8 12 8"
                  HeadersVisibility="Column"
                  VerticalScrollBarVisibility="Auto"
                  Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT"
                                    Binding="{Binding STT}"
                                    Width="80"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Họ Tên"
                                    Binding="{Binding HoTen}"
                                    Width="2*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Giới Tính"
                                    Binding="{Binding GioiTinh}"
                                    Width="*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Năm Sinh"
                                    Binding="{Binding NamSinh}"
                                    Width="*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
                <DataGridTextColumn Header="Địa Chỉ"
                                    Binding="{Binding DiaChi}"
                                    Width="2*"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ===== NÚT THAO TÁC ===== -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,16">
            <Button Content="Thêm bệnh nhân"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Margin="0,0,12,0"
                    Click="BtnThemBenhNhan_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountPlus" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Thêm bệnh nhân" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Content="Xóa"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Margin="0,0,12,0"
                    Click="BtnXoa_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Xóa" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Content="Lưu danh sách"
                    Style="{StaticResource MaterialDesignRaisedAccentButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="BtnLuu_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Lưu danh sách" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!-- ===== QUY ĐỊNH ===== -->
        <materialDesign:Card Grid.Row="5"
                             Padding="12"
                             Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,4">
                    <Run Text="Quy định 1:"/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="13"
                           Text="Có 2 loại phòng Khám: Phòng khám Thường và Phòng khám VIP. Số bệnh nhân khám tối đa mỗi ngày của Phòng khám Thường, Phòng khám VIP lần lượt là 40, 20."/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
